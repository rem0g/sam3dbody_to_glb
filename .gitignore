# User data — keep the folders, ignore their contents
/input/*
!/input/.gitkeep
!/input/README.md
/output/*
!/output/.gitkeep
!/output/README.md

# Large MHR model assets — download via assets/README.md
/assets/*
!/assets/README.md

# Stray data files anywhere else in the tree
*.sam3dbody
*.glb
*.mp4
# (mhr_faces_lod1.npy *is* committed — it's small and the renderers need it)

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
.DS_Store
